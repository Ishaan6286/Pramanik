# Amazon Bedrock (primary AI)
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=ap-south-1

# Deepseek via NVIDIA (Ultimate RAG AI - primary for chatbot)
DEEPSEEK_API_KEY=your_nvidia_api_key_here
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1

# Groq (fallback AI — used if Bedrock fails)
GROQ_API_KEY=your_groq_api_key_here

# Supabase Database
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
