# Amazon Bedrock (optional AI provider — set AI_PROVIDER=bedrock to use)
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=ap-south-1

# AI Provider — groq (default, free) or bedrock (enterprise)
AI_PROVIDER=groq

# Deepseek via NVIDIA (Ultimate RAG AI - primary for chatbot)
DEEPSEEK_API_KEY=your_nvidia_api_key_here
DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1

# Groq (fallback AI — used if Bedrock fails, or primary if AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# Supabase Database
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# CORS — comma-separated list of allowed frontend origins
# Example: https://pramanik.vercel.app
# Leave empty to allow all (development only)
CORS_ORIGINS=https://your-vercel-app.vercel.app

# Optional: default GitHub token for webhook scans
GITHUB_DEFAULT_TOKEN=
