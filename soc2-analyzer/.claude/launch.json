{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5180"],
      "port": 5180,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--port", "3001"],
      "port": 3001,
      "cwd": "backend"
    }
  ]
}
